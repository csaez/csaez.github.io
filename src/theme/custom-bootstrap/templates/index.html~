{% extends "base.html" %}

{% block header %}
{% include "carousel.html" %}
{% endblock header %}

{% block content %}

{% for article in articles_page.object_list %}
<div class="container">
  <div>
    <p class="tags lead">
      {% for tag in article.tags %}
      <a href="{{ SITEURL }}/{{ tag.url }}">{{ tag }}</a>{% if not loop.last %}, {% endif %}
      {% endfor %}
    </p>
    <h1 class="article-title"><a href="{{ SITEURL }}/{{ article.url }}">{{ article.title }}</a></h1>
    <ul class="list-inline">
      <li class="text-muted"><span class="glyphicon glyphicon-time"></span> {{ article.locale_date }}</li>
      <li class="text-muted"><span class="glyphicon glyphicon-user"></span> {{ article.author }}</li>
      <li class="text-muted"><span class="glyphicon glyphicon-comment"></span> <a href="{{ article.url }}#disqus_thread">Comments</a></li>
    </ul>
  </div>

  {% if article.image %}
  <a href="{{ SITEURL }}/{{ article.url }}"><img src="{{ article.image }}" class="img-responsive"></a>
  {% endif %}
  <hr>

  <div class="article-content">{{ article.summary }}</div>
  {% if article.summary != article.content %}
  <a href="{{ SITEURL }}/{{ article.url }}">Read More &raquo;</a>
  {% endif %}
</div>

{% if not loop.last %}
<hr class="post-separator">
{% endif %}

{% endfor %}
<div class="container">
{% include 'pagination.html' %}
</div>

{% endblock content %}
